# ─── 必填：DeepSeek API Key（默认 provider，OpenAI 兼容协议） ───
DEEPSEEK_API_KEY=sk-your-key-here

# ─── 可选：覆盖默认配置（不填即用默认值） ───
# 模型名
# CS_MODEL=deepseek-chat
# API 基址（切换到 OpenAI 兼容的其它服务时改这里）
# CS_BASE_URL=https://api.deepseek.com
# 采样温度
# CS_TEMPERATURE=0.3
# 单个 Agent 的 ReAct 循环最大步数（防死循环）
# CS_MAX_STEPS=5
# 单次 LLM 请求超时（秒）
# CS_TIMEOUT=10
